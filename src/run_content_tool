from content_tool import main as create_seed_main
from create_facebook_draft import main as create_facebook_draft_main


def show_menu() -> None:
    print("\nEddie's Content Tools")
    print("---------------------")
    print("1. Create a new seed from date/category")
    print("2. Create Facebook draft from saved seed")
    print("3. Full flow: create seed, then create Facebook draft")
    print("4. Quit")


def main() -> None:
    while True:
        show_menu()

        choice = input("\nChoose an option: ").strip()

        if choice == "1":
            create_seed_main()

        elif choice == "2":
            create_facebook_draft_main()

        elif choice == "3":
            create_seed_main()
            print("\nNow create the Facebook draft from the saved seed.\n")
            create_facebook_draft_main()

        elif choice == "4" or choice.lower() in {"q", "quit", "exit"}:
            print("Done.")
            break

        else:
            print("Invalid choice. Try again.")


if __name__ == "__main__":
    main()
    